#!/home/vijay-katta/faster-whisper-env/bin/python3
"""Transcription engine. Connects to persistent server for instant Parakeet, or runs Whisper directly."""
import sys
import os
import socket
import subprocess
import time
import warnings
import logging

warnings.filterwarnings('ignore')
for name in ['nemo', 'pytorch_lightning', 'nemo.collections', 'nemo.utils',
             'nemo.core', 'torch', 'transformers']:
    logging.getLogger(name).setLevel(logging.CRITICAL)
os.environ['NEMO_LOG_LEVEL'] = 'CRITICAL'
os.environ['HYDRA_FULL_ERROR'] = '0'

audio_file = sys.argv[1]
engine = os.environ.get('VOICE_ENGINE', 'parakeet')
model_name = os.environ.get('VOICE_MODEL', '')
language = os.environ.get('VOICE_LANG', 'en')

SOCKET_PATH = "/tmp/voice-transcribe.sock"
SERVER_SCRIPT = os.path.expanduser("~/bin/voice-transcribe-server")
SERVER_PID_FILE = "/tmp/voice-transcribe-server.pid"
LOGFILE = "/tmp/voice-to-text.log"

def log(msg):
    try:
        with open(LOGFILE, 'a') as f:
            f.write(f"{time.strftime('%H:%M:%S')} [engine] {msg}\n")
    except:
        pass

def transcribe_via_server(audio_file):
    """Send audio file path to persistent server, get text back."""
    sock = socket.socket(socket.AF_UNIX, socket.SOCK_STREAM)
    sock.settimeout(30)
    sock.connect(SOCKET_PATH)
    sock.sendall(audio_file.encode('utf-8'))
    chunks = []
    while True:
        chunk = sock.recv(4096)
        if not chunk:
            break
        chunks.append(chunk)
    sock.close()
    response = b''.join(chunks).decode('utf-8')
    if response.startswith("ERROR:"):
        raise RuntimeError(response)
    if "__TIME__" in response:
        text, elapsed = response.rsplit("__TIME__", 1)
        log(f"Server transcribed in {elapsed}s")
        return text.strip()
    return response.strip()

def server_is_running():
    """Check if server socket exists and responds."""
    if not os.path.exists(SOCKET_PATH):
        return False
    try:
        sock = socket.socket(socket.AF_UNIX, socket.SOCK_STREAM)
        sock.settimeout(2)
        sock.connect(SOCKET_PATH)
        sock.sendall(b"PING")
        resp = sock.recv(64)
        sock.close()
        return resp == b"PONG"
    except:
        return False

def start_server():
    """Start the persistent transcription server in background."""
    log("Starting transcription server...")
    with open("/tmp/voice-transcribe-server.log", "w") as logf:
        subprocess.Popen(
            [sys.executable, SERVER_SCRIPT],
            stdout=logf, stderr=logf,
            start_new_session=True,
        )
    # Wait for server to be ready (model loading takes ~10s)
    for i in range(120):  # up to 60 seconds
        time.sleep(0.5)
        if server_is_running():
            log(f"Server ready after {(i+1)*0.5:.1f}s")
            return True
    log("Server failed to start within 60s")
    return False

def transcribe_parakeet(audio_file):
    """Transcribe via persistent server (instant) or start server first."""
    if server_is_running():
        return transcribe_via_server(audio_file)
    log("Server not running, starting it...")
    if start_server():
        return transcribe_via_server(audio_file)
    # Fallback: direct load (slow but works)
    log("Falling back to direct model load")
    return transcribe_parakeet_direct(audio_file)

def transcribe_parakeet_direct(audio_file):
    """Direct model load fallback (slow ~11s)."""
    import nemo.utils.nemo_logging
    nemo.utils.nemo_logging.Logger().setLevel(logging.CRITICAL)
    import nemo.collections.asr as nemo_asr
    from omegaconf import open_dict
    model = nemo_asr.models.ASRModel.from_pretrained('nvidia/parakeet-tdt-0.6b-v3')
    model.eval()
    with open_dict(model.cfg):
        model.cfg.decoding.greedy.use_cuda_graph_decoder = False
    model.change_decoding_strategy(model.cfg.decoding)
    result = model.transcribe([audio_file])
    if isinstance(result, list) and len(result) > 0:
        r = result[0]
        return r.text if hasattr(r, 'text') else str(r)
    return str(result)

def transcribe_whisper(audio_file, model_name, language):
    from faster_whisper import WhisperModel
    if not model_name:
        model_name = 'base'
    model = WhisperModel(model_name, device='cpu', compute_type='int8')
    segments, _ = model.transcribe(
        audio_file,
        language=language,
        beam_size=5,
        vad_filter=True,
        vad_parameters=dict(min_silence_duration_ms=500, speech_pad_ms=300),
        no_speech_threshold=0.5,
        log_prob_threshold=-1.0,
        condition_on_previous_text=True,
    )
    return ' '.join(s.text.strip() for s in segments)

if engine == 'parakeet':
    text = transcribe_parakeet(audio_file)
elif engine == 'whisper':
    text = transcribe_whisper(audio_file, model_name, language)
else:
    print(f'Unknown engine: {engine}', file=sys.stderr)
    sys.exit(1)

print(text)
