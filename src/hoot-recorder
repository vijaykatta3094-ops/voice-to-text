#!/home/vijay-katta/faster-whisper-env/bin/python3
"""Background audio recorder. Uses sounddevice for zero-loss recording."""
import signal
import sys
import wave
import os
import queue
import threading
import numpy as np
import sounddevice as sd

AUDIO_FILE = sys.argv[1] if len(sys.argv) > 1 else "/tmp/hoot-recording.wav"
READY_FILE = "/tmp/hoot.ready"
LEVEL_FILE = "/tmp/hoot.level"
RATE = 16000
CHANNELS = 1

def main():
    pidfile = "/tmp/hoot.pid"
    with open(pidfile, "w") as f:
        f.write(str(os.getpid()))

    audio_queue = queue.Queue()
    stopped = threading.Event()
    DROPOUT_FILE = "/tmp/hoot.dropout"

    # BT dropout detection: count consecutive zero-only blocks
    consecutive_zero_blocks = [0]
    had_speech = [False]
    # After 0.5s of speech, 1.5s of zeros = BT dropped → stop recording
    ZERO_BLOCK_DROPOUT_THRESHOLD = 30  # 30 * 50ms = 1.5s of zeros after speech

    def callback(indata, frames, time_info, status):
        if status:
            # Log sounddevice errors (overflow, underflow, etc.)
            with open("/tmp/hoot.log", "a") as f:
                f.write(f"[recorder] sounddevice status error: {status}\n")
        data = bytes(indata)
        # Detect all-zero frames (BT source dropped)
        if all(b == 0 for b in data):
            consecutive_zero_blocks[0] += 1
            if had_speech[0] and consecutive_zero_blocks[0] >= ZERO_BLOCK_DROPOUT_THRESHOLD:
                # BT dropped after speech started — stop recording
                with open(DROPOUT_FILE, "w") as f:
                    f.write("BT dropout detected")
                stopped.set()
                return
        else:
            consecutive_zero_blocks[0] = 0
            had_speech[0] = True
        audio_queue.put(data)

    def write_level(data):
        """Compute RMS amplitude and write normalized level (0.0–1.0) for the panel indicator."""
        samples = np.frombuffer(data, dtype=np.int16).astype(np.float32)
        rms = np.sqrt(np.mean(samples ** 2))
        level = min(1.0, rms / 8000.0)
        try:
            with open(LEVEL_FILE, 'w') as lf:
                lf.write(f"{level:.3f}")
        except OSError:
            pass

    def handle_signal(signum, frame):
        stopped.set()

    signal.signal(signal.SIGTERM, handle_signal)
    signal.signal(signal.SIGINT, handle_signal)

    wf = wave.open(AUDIO_FILE, "wb")
    wf.setnchannels(CHANNELS)
    wf.setsampwidth(2)
    wf.setframerate(RATE)

    stream = sd.RawInputStream(
        samplerate=RATE, channels=CHANNELS, dtype="int16",
        blocksize=800, callback=callback,  # 50ms blocks
    )
    stream.start()

    # Signal to the main script that recording has actually started
    open(READY_FILE, "w").close()

    try:
        while not stopped.is_set():
            try:
                data = audio_queue.get(timeout=0.05)
                wf.writeframes(data)
                write_level(data)
            except queue.Empty:
                pass

        # Stop stream first, then drain remaining queued audio
        stream.stop()
        while not audio_queue.empty():
            try:
                wf.writeframes(audio_queue.get_nowait())
            except queue.Empty:
                break
        # Append 1.5s of silence so Parakeet can finalize the last word
        silence_frames = int(1.5 * RATE)
        wf.writeframes(b'\x00\x00' * silence_frames)
    finally:
        stream.close()
        wf.close()
        try:
            os.unlink(LEVEL_FILE)
        except OSError:
            pass

if __name__ == "__main__":
    main()
